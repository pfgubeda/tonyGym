"bilbo.instructions.what.title" = "¿Qué es el Método BILBO?";
"bilbo.instructions.what.content" = "El Método BILBO es un sistema de entrenamiento de fuerza e hipertrofia desarrollado por Jesús Varela. Se enfoca en realizar series explosivas de 15-50 repeticiones con aproximadamente el 50% de tu repetición máxima (1RM), dejando siempre entre 1-3 repeticiones en reserva.";
"bilbo.instructions.how.title" = "¿Cómo funciona?";
"bilbo.instructions.how.content" = "1. Comienza con el 50% de tu 1RM para cada ejercicio\n2. Realiza repeticiones explosivas\n3. Completa 15-50 repeticiones manteniendo entre 1-3 repeticiones en reserva\n4. Progresa aumentando el peso cuando superes las 15 repeticiones";
"bilbo.instructions.steps.title" = "Pasos del Entrenamiento";
"bilbo.instructions.steps.content" = "1. Calienta adecuadamente\n2. Carga el 50% de tu 1RM\n3. Realiza repeticiones explosivas\n4. Para cuando tengas entre 1-3 repeticiones en reserva\n5. Registra tu rendimiento\n6. Progresa el peso si completaste más de 15 repeticiones";
"bilbo.instructions.benefits.title" = "Beneficios";
"bilbo.instructions.benefits.content" = "• Mejora de la potencia explosiva\n• Aumento de la masa muscular\n• Mejor resistencia de fuerza\n• Reducción del riesgo de lesiones\n• Mejor desarrollo de la técnica\n• Progresión sostenible";
"bilbo.instructions.tips.title" = "Consejos Importantes";
"bilbo.instructions.tips.content" = "• Mantén siempre una técnica adecuada\n• Nunca llegues al fallo muscular\n• Enfócate en el movimiento explosivo\n• Descansa 48-72 horas entre sesiones\n• Progresa gradualmente (aumentos de 2kg)\n• Escucha a tu cuerpo";

